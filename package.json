{
  "name": "lumeline",
  "version": "0.1.0",
  "description": "LumeLine — Odds Intelligence Platform | Trust Layer Ecosystem",
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
    "db:init": "node db/init.js",
    "ingest": "node -e \"import('./server/ingestion.js').then(m => m.runIngestion())\"",
    "pipeline": "node -e \"fetch('http://localhost:3000/api/pipeline',{method:'POST'}).then(r=>r.json()).then(console.log)\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "resend": "^4.1.0",
    "stripe": "^17.0.0",
    "twilio": "^5.4.0"
  },
  "keywords": ["odds", "sports", "betting", "intelligence", "transparency", "trust-layer", "lume"],
  "author": "DarkWave Studios",
  "license": "MIT"
}
