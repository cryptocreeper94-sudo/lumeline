# ═══════════════════════════════════════════════════════
#  LumeLine — Environment Configuration
#  Copy to .env and fill in values
# ═══════════════════════════════════════════════════════

# ─── Database (Neon Serverless PostgreSQL) ───
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/lumeline?sslmode=require

# ─── The Odds API ───
ODDS_API_KEY=your_key_here
ODDS_API_BASE=https://api.the-odds-api.com/v4

# ─── OpenAI (for consensus AI reasoning) ───
OPENAI_API_KEY=sk-your-key-here

# ─── Server ───
PORT=3000
NODE_ENV=production

# ─── Ingestion Schedule (tiered polling to stay under 500 req/day free tier) ───
INGESTION_INTERVAL_MINUTES=15
# Core: polled every 30 min (192 req/day for 4 sports)
CORE_SPORTS=americanfootball_nfl,basketball_nba,baseball_mlb,icehockey_nhl
# Secondary: polled every 60 min (~288 req/day for 11 sports)
SECONDARY_SPORTS=americanfootball_ncaaf,basketball_ncaab,basketball_wnba,soccer_epl,soccer_spain_la_liga,soccer_usa_mls,mma_mixed_martial_arts,tennis_atp,cricket_ipl,rugbyleague_nrl,golf_masters_tournament_winner

# ─── Scoring Thresholds ───
SHARP_THRESHOLD=62
RELIABLE_THRESHOLD=55
FADE_THRESHOLD=48

# ─── Anomaly Detection ───
SYNC_WINDOW_MINUTES=5
SYNC_MIN_SOURCES=3
DIVERGENCE_THRESHOLD=3.5
INTEGRITY_CRITICAL=40

# ─── Consensus Engine ───
CONFIDENCE_THRESHOLD=60
MIN_SOURCES_FOR_CONSENSUS=3
HOUSE_LEAN_ENABLED=true

# ─── Twilio (SMS Alerts) ───
TWILIO_SID=ACxxxxxxxxxx
TWILIO_AUTH=your_auth_token
TWILIO_PHONE=+1234567890
